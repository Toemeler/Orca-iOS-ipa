+# Orca-iOS-ipa step 1: minimal slicing CLI for GUI-less cross builds.
+if (NOT SLIC3R_GUI AND EXISTS ${CMAKE_CURRENT_SOURCE_DIR}/smoke_cli.cpp)
+    add_executable(orca_smoke_cli ${CMAKE_CURRENT_SOURCE_DIR}/smoke_cli.cpp)
+    target_link_libraries(orca_smoke_cli libslic3r libslic3r_cgal)
+endif ()
+
+# Orca-iOS-ipa step-1 harness: a minimal CLI linking libslic3r, used to prove
+# the slicing engine on iOS. Only built when the source file has been copied in.
+if (EXISTS ${CMAKE_CURRENT_LIST_DIR}/orca-core-cli.cpp)
+    add_executable(orca-core-cli orca-core-cli.cpp)
+    target_link_libraries(orca-core-cli libslic3r boost_headeronly libcurl OpenSSL::SSL OpenSSL::Crypto)
+endif ()
